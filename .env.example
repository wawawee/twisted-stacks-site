# Optional — only for local CLI deploy/debug (not needed for Vercel Git deploys)
GITHUB_TOKEN_WAWAWEE=
VERCEL_TOKEN=

# Server-side Supabase config for Vercel /api/leaderboard and /api/contact.
# SUPABASE_SERVICE_ROLE_KEY must only live in Vercel/local server env, never with a VITE_ prefix.
SUPABASE_URL=https://oeppjpbaafjsowecyjho.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional override for the browser leaderboard client. Defaults to /api/leaderboard.
VITE_LEADERBOARD_API_PATH=

# --- Contact form (Vercel /api/contact) ---
# Always required (server reads SUPABASE_* above for storage):
#
# Optional — turn on email forwarding. Without these, /api/contact stores
# submissions in Supabase and returns success; the operator triages them
# in the Studio. With these set, the same submissions are also emailed to
# hello@twistedstacks.com and the submitter gets an auto-reply.
#
# Get a free key at https://resend.com (100 emails/day, 3000/month on free).
# The domain "twistedstacks.com" must be verified in Resend before the
# first send will succeed.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=TwistedStacks <hello@twistedstacks.com>
CONTACT_TO_EMAIL=hello@twistedstacks.com
CONTACT_NOTIFY_EMAIL=dev@twistedstacks.com

# --- SUPARAYS team room (/suparays) ---
SUPARAYS_ROOM_PASSWORD=baha123
# Optional HMAC secret (defaults to password if unset)
# SUPARAYS_ROOM_SECRET=
# Reply-To defaults to the submitter's email when forwarding; override here.
# CONTACT_REPLY_TO=
